<!-- windows/MiniWindow.xaml -->
<Window x:Class="MeetingAssistant.Windows.MiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Assistant"
        Width="360" Height="220"
        Topmost="True"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0">
      <Ellipse Width="10" Height="10" Fill="{Binding IsRecording, Converter={StaticResource BoolToBrushConverter}}" Margin="0,0,8,0"/>
      <TextBlock Text="{Binding StatusText}" FontWeight="Bold"/>
      <Button Content="×" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="Close_Click" />
    </DockPanel>

    <StackPanel Orientation="Horizontal" Spacing="8" Grid.Row="1" Margin="0,8,0,8">
      <Button Content="{Binding RecordButtonText}" Click="Record_Click"/>
      <Button Content="Bookmark" Click="Bookmark_Click"/>
      <Button Content="What’s been going on?" Click="Summarize_Click"/>
    </StackPanel>

    <StackPanel Grid.Row="2">
      <TextBlock Text="Summary" Foreground="Gray" FontSize="12"/>
      <ScrollViewer Height="100">
        <TextBlock Text="{Binding LastSummary}" TextWrapping="Wrap"/>
      </ScrollViewer>
    </StackPanel>
  </Grid>
</Window>
